# Configuración del Servidor
PORT=4000
NODE_ENV=development

# Servex API Configuration
SERVEX_API_KEY=sx_xxxxxxxxxxxxxxxxxxxxxxxxxx
SERVEX_BASE_URL=https://servex.ws/api
SERVEX_TIMEOUT=30000

# MercadoPago Configuration
MP_ACCESS_TOKEN=APP-XXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
MP_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXXXX-XXXX-XXXX-XXXXXXXXXXXX
MP_WEBHOOK_URL=https://tu-dominio.com/api

# Database
DATABASE_PATH=./database/secureshop.db

# CORS
# CORS_ORIGIN acepta múltiples orígenes separados por comas.
# - Usa '*' para permitir cualquier origen (no recomendado en producción, y menos con credentials).
# - Para WebView/Capacitor, el navegador puede enviar Origin: null; se permite SOLO si incluyes 'null' en la lista.
# Ejemplos:
#   CORS_ORIGIN=http://localhost:3000,https://shop.jhservices.com.ar
#   CORS_ORIGIN=capacitor://localhost,http://localhost:3000
#   CORS_ORIGIN=http://localhost:3000,capacitor://localhost,null
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
